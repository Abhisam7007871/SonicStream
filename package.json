{
  "name": "music-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node server.js",
    "dev:next": "next dev",
    "dev:backend": "cd backend && npm run dev",
    "build:backend": "cd backend && npx tsc --project tsconfig.json --noEmit false --skipLibCheck true 2>&1; true",
    "build:next": "next build",
    "build": "npm run prisma:generate && npm run build:backend && npm run build:next",
    "start": "NODE_ENV=production node server.js",
    "lint": "eslint",
    "prisma:generate": "cd backend && npx prisma generate --schema=prisma/schema.prisma",
    "postinstall": "cd backend && npm install"
  },
  "dependencies": {
    "@types/howler": "^2.2.12",
    "dotenv": "^17.4.2",
    "howler": "^2.2.4",
    "lucide-react": "^1.8.0",
    "next": "^14.2.23",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-player": "^3.4.0",
    "ts-node": "^10.9.2",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.23",
    "typescript": "^5"
  }
}
